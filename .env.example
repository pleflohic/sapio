# Copier en .env (gitignoré) et renseigner.
# Précédence de configuration : flag CLI > .env > défaut codé.

# --- Provider ---
SAPIO_PROVIDER=anthropic        # anthropic | openrouter

# --- Modèles par étape ---
# Extraction = lecture d'imprimé + structuration → un modèle économique suffit.
# Notation   = jugement de rigueur sur manuscrit → modèle de pointe.
SAPIO_EXTRACT_MODEL=claude-sonnet-4-6
SAPIO_REVIEW_MODEL=claude-opus-4-8
# (repli commun si l'un des deux est absent : SAPIO_MODEL)

# --- Authentification (selon le provider) ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# --- Réglages amenés à évoluer (facultatifs) ---
# SAPIO_DPI=150            # résolution de rendu des pages
# SAPIO_BATCH_PAGES=0      # 0 = toute la plage en un seul appel
